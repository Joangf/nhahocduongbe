# Copy this file to .env and fill in your values
# Do NOT commit .env to git

# ── PostgreSQL (Supabase pooler) ──────────────────────────────────────────────
DB_URL=jdbc:postgresql://your-pooler-host:6543/postgres?sslmode=require&currentSchema=nhahocduong&prepareThreshold=0
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=your-database-password

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32 | xxd -p | tr -d '\n'  (must be Base64-encoded 32-byte key)
JWT_SIGNING_KEY=replace-with-your-base64-encoded-32-byte-secret
# Token expiry in milliseconds (default 2592000000 = 30 days)
JWT_EXPIRATION_MS=2592000000

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
